import React, { useState } from "react";
import { Coins, Plus, Calendar, Clock, ArrowRightLeft, DollarSign, Archive, Flame, AlertTriangle, Trash2 } from "lucide-react";
import { HarvestItem, Reminder } from "../types";

interface HarvestModuleProps {
  harvests: HarvestItem[];
  reminders: Reminder[];
  onAddHarvest: (harvest: Omit<HarvestItem, "id" | "status">) => void;
  onDeleteHarvest: (id: string) => void;
  onSellHarvest: (id: string) => void;
  onAddReminder: (moduleId: "harvest", title: string, desc: string, time: string, repeat: "none" | "daily" | "weekly") => void;
  onNavigateToAdvisor: (cropName: string) => void;
  currentTimeStr: string;
}

export const HarvestModule: React.FC<HarvestModuleProps> = ({
  harvests,
  reminders,
  onAddHarvest,
  onDeleteHarvest,
  onSellHarvest,
  onAddReminder,
  onNavigateToAdvisor,
  currentTimeStr
}) => {
  const [showAddForm, setShowAddForm] = useState(false);
  const [showReminderForm, setShowReminderForm] = useState(false);

  // Harvest form states
  const [cropName, setCropName] = useState("");
  const [quantity, setQuantity] = useState("");
  const [marketName, setMarketName] = useState("");
  const [targetPrice, setTargetPrice] = useState("");
  const [hrsToExpiry, setHrsToExpiry] = useState("24");

  // Alarm states
  const [remTitle, setRemTitle] = useState("");
  const [remDesc, setRemDesc] = useState("");
  const [remTime, setRemTime] = useState("");
  const [remRepeat, setRemRepeat] = useState<"none" | "daily" | "weekly">("none");

  const handleCreateHarvest = (e: React.FormEvent) => {
    e.preventDefault();
    if (!cropName || !quantity || !marketName || !targetPrice) return;
    
    // Calculate sell deadline based on hrsToExpiry
    const harvestDate = new Date(currentTimeStr);
    const deadlineDate = new Date(harvestDate.getTime() + (Number(hrsToExpiry) * 60 * 60 * 1000));

    onAddHarvest({
      cropName,
      quantity,
      harvestDate: currentTimeStr,
      sellDeadline: deadlineDate.toISOString(),
      marketName,
      targetPricePerUnit: targetPrice,
    });

    setCropName("");
    setQuantity("");
    setMarketName("");
    setTargetPrice("");
    setShowAddForm(false);
  };

  const handleCreateReminder = (e: React.FormEvent) => {
    e.preventDefault();
    if (!remTitle || !remTime) return;
    onAddReminder(
      "harvest",
      remTitle,
      remDesc || `Harvest market sell reminder`,
      remTime,
      remRepeat
    );
    setRemTitle("");
    setRemDesc("");
    setRemTime("");
    setShowReminderForm(false);
  };

  const getVeggieLogistics = (item: HarvestItem) => {
    try {
      const start = new Date(item.harvestDate).getTime();
      const end = new Date(item.sellDeadline).getTime();
      const now = new Date(currentTimeStr).getTime();

      if (item.status === "sold") return { freshness: 100, label: "Sold", iconColor: "text-emerald-400" };
      if (now >= end) return { freshness: 0, label: "Spoiled / Expired", iconColor: "text-red-500" };

      const totalDuration = end - start;
      const elapsed = now - start;
      const progress = Math.max(0, Math.min(100, Math.round(100 - (elapsed / totalDuration * 100))));
      
      let label = "Fresh";
      let iconColor = "text-emerald-400";
      if (progress < 30) {
        label = "Critical: Spoils soon!";
        iconColor = "text-red-400 animate-pulse";
      } else if (progress < 65) {
        label = "Moderate freshness";
        iconColor = "text-amber-400";
      }

      return { freshness: progress, label, iconColor };
    } catch {
      return { freshness: 80, label: "Fresh", iconColor: "text-emerald-400" };
    }
  };

  const autofillReminder = (item: HarvestItem) => {
    const timeOnly = currentTimeStr.split("T")[1]?.substring(0, 5) || "05:00";
    setRemTitle(`🛒 Sell ${item.cropName} at ${item.marketName}`);
    setRemDesc(`Load ${item.quantity} of harvested veggies and drive to market for selling on time.`);
    setRemTime(timeOnly);
    setShowReminderForm(true);
  };

  return (
    <div className="flex-1 overflow-y-auto px-4 py-3 pb-8 text-zinc-100 bg-zinc-950 font-sans cursor-default">
      
      {/* Header Info */}
      <div className="flex justify-between items-center mb-4">
        <div>
          <h2 className="text-lg font-black text-teal-400 flex items-center gap-2">
            <Coins className="w-5 h-5" /> Module 3: Harvest Sells
          </h2>
          <p className="text-[11px] text-zinc-400">Timers and alerts to sell agricultural crops to markets before drying</p>
        </div>
      </div>

      {/* Buttons */}
      <div className="grid grid-cols-2 gap-2 mb-4">
        <button
          type="button"
          onClick={() => { setShowAddForm(!showAddForm); setShowReminderForm(false); }}
          className="flex items-center justify-center gap-1.5 p-2 bg-teal-500/10 border border-teal-500/20 text-teal-400 rounded-xl text-xs font-bold hover:bg-teal-500/20 transition-all"
        >
          <Plus className="w-4 h-4" /> Log Fresh Harvest
        </button>
        <button
          type="button"
          onClick={() => { setShowReminderForm(!showReminderForm); setShowAddForm(false); }}
          className="flex items-center justify-center gap-1.5 p-2 bg-amber-500/10 border border-amber-500/20 text-amber-500 rounded-xl text-xs font-bold hover:bg-amber-500/25 transition-all"
        >
          <Calendar className="w-4 h-4" /> Market Alert
        </button>
      </div>

      {/* Form 1: Add Harvest */}
      {showAddForm && (
        <form onSubmit={handleCreateHarvest} className="mb-4 bg-zinc-900 border border-zinc-800 rounded-xl p-3 text-xs space-y-2.5">
          <h3 className="font-bold text-zinc-200">Register Harvested Crops</h3>

          <div className="space-y-1">
            <label className="text-zinc-400">Vegetable / Fruit Name</label>
            <input 
              required
              type="text" 
              value={cropName}
              onChange={e => setCropName(e.target.value)}
              placeholder="e.g. Fresh Tomatoes / Green Chilies" 
              className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-200 font-bold"
            />
          </div>

          <div className="grid grid-cols-2 gap-2">
            <div className="space-y-1">
              <label className="text-zinc-400">Quantity (e.g. kg, crates)</label>
              <input 
                required
                type="text" 
                value={quantity}
                onChange={e => setQuantity(e.target.value)}
                placeholder="e.g. 120 Kilograms" 
                className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-200"
              />
            </div>
            <div className="space-y-1">
              <label className="text-zinc-400">Target Market Place</label>
              <input 
                required
                type="text" 
                value={marketName}
                onChange={e => setMarketName(e.target.value)}
                placeholder="e.g. Azadpur Subzi Mandi" 
                className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-200"
              />
            </div>
          </div>

          <div className="grid grid-cols-2 gap-2">
            <div className="space-y-1">
              <label className="text-zinc-400">Asking Price (per unit)</label>
              <input 
                required
                type="text" 
                value={targetPrice}
                onChange={e => setTargetPrice(e.target.value)}
                placeholder="e.g. ₹35 / kg" 
                className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-200 font-mono text-[11px]"
              />
            </div>
            <div className="space-y-1">
              <label className="text-zinc-400">Freshness window (hours)</label>
              <select 
                value={hrsToExpiry}
                onChange={e => setHrsToExpiry(e.target.value)}
                className="w-full bg-zinc-950 border border-zinc-800 p-1.5 rounded text-zinc-200 font-mono text-[11px]"
              >
                <option value="6">6 Hours (Leafy spinach)</option>
                <option value="12">12 Hours (Fast rot)</option>
                <option value="24">24 Hours (Standard veggie)</option>
                <option value="48">48 Hours (Guavas, Apples)</option>
                <option value="120">5 Days (Potatoes / Grains)</option>
              </select>
            </div>
          </div>

          <div className="flex gap-2 justify-end pt-1">
            <button 
              type="button" 
              onClick={() => setShowAddForm(false)}
              className="px-3 py-1.5 bg-zinc-800 border border-zinc-700 text-zinc-400 rounded hover:bg-zinc-700"
            >
              Cancel
            </button>
            <button 
              type="submit" 
              className="px-3 py-1.5 bg-teal-600 border border-teal-500 text-black font-bold rounded hover:bg-teal-500"
            >
              Log Harvest
            </button>
          </div>
        </form>
      )}

      {/* Form 2: Add Alarm */}
      {showReminderForm && (
        <form onSubmit={handleCreateReminder} className="mb-4 bg-zinc-900 border border-zinc-800 rounded-xl p-3 text-xs space-y-2.5">
          <h3 className="font-bold text-amber-400">Setup Vegetable market Alarms</h3>

          <div className="space-y-1">
            <label className="text-zinc-400">Alarm Alert Title</label>
            <input 
              required
              type="text" 
              value={remTitle} 
              onChange={e => setRemTitle(e.target.value)}
              placeholder="e.g. 🚛 Start transport for Tomato sacks" 
              className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-100 font-bold"
            />
          </div>

          <div className="space-y-1">
            <label className="text-zinc-400">Short Note</label>
            <input 
              type="text" 
              value={remDesc} 
              onChange={e => setRemDesc(e.target.value)}
              placeholder="e.g. Load onto vehicle, secure the tarp, meet dealer Kumar." 
              className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-200"
            />
          </div>

          <div className="grid grid-cols-2 gap-2">
            <div className="space-y-1">
              <label className="text-zinc-400">Alarm trigger Time</label>
              <input 
                required
                type="text" 
                value={remTime} 
                onChange={e => setRemTime(e.target.value)}
                placeholder="24h e.g. 05:00 or 15:00" 
                className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-100 font-mono"
              />
            </div>
            <div className="space-y-1">
              <label className="text-zinc-400">Alarm Type</label>
              <select 
                value={remRepeat} 
                onChange={e => setRemRepeat(e.target.value as any)}
                className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-100"
              >
                <option value="none">One-time prompt (Today)</option>
                <option value="daily">Daily repetitive (Every morning)</option>
              </select>
            </div>
          </div>

          <div className="flex gap-2 justify-end pt-1">
            <button 
              type="button" 
              onClick={() => setShowReminderForm(false)}
              className="px-3 py-1.5 bg-zinc-800 border border-zinc-700 text-zinc-400 rounded hover:bg-zinc-700"
            >
              Cancel
            </button>
            <button 
              type="submit" 
              className="px-3 py-1.5 bg-amber-600 border border-amber-500 text-black font-semibold rounded hover:bg-amber-500"
            >
              Activate Alarm
            </button>
          </div>
        </form>
      )}

      {/* Harvest display items */}
      <div className="space-y-3 mb-5">
        <h3 className="text-xs uppercase tracking-wider text-zinc-400 font-bold mb-1">Crops Pending Sale</h3>
        {harvests.length === 0 ? (
          <div className="text-center py-6 bg-zinc-900 border border-zinc-850 rounded-2xl text-xs text-zinc-500">
            🌾 No pending freshly harvested stock records. Log your harvest and track deadlines above!
          </div>
        ) : (
          harvests.map(item => {
            const logistics = getVeggieLogistics(item);
            const isSold = item.status === "sold";
            const isSpoiled = logistics.freshness === 0 && !isSold;

            return (
              <div 
                key={item.id} 
                className={`p-3 bg-zinc-900 border rounded-2xl transition-all ${
                  isSpoiled 
                    ? "border-red-500/40 bg-red-500/5" 
                    : isSold 
                      ? "border-emerald-500/25 bg-emerald-500/5 opacity-80" 
                      : logistics.freshness < 30 
                        ? "border-amber-500/40 bg-amber-500/5" 
                        : "border-zinc-800"
                }`}
              >
                {/* Header detail */}
                <div className="flex justify-between items-start mb-2">
                  <div>
                    <h4 className="font-bold text-[14px] text-zinc-100 flex items-center gap-1.5">
                      <span className={`text-xs py-0.5 px-2 rounded font-mono border font-bold ${
                        isSold 
                          ? "bg-emerald-500/10 text-emerald-400 border-emerald-500/10" 
                          : isSpoiled 
                            ? "bg-red-500/10 text-red-500 border-red-500/10"
                            : "bg-teal-500/10 text-teal-400 border-teal-500/10"
                      }`}>
                        {item.quantity}
                      </span>
                      {item.cropName}
                    </h4>
                    <span className="text-[10px] text-zinc-400 block mt-0.5">
                      🚜 Market: <span className="font-bold text-zinc-300">{item.marketName}</span> • Rate: <span className="text-teal-400 font-bold">{item.targetPricePerUnit}</span>
                    </span>
                  </div>
                  <button 
                    type="button"
                    onClick={() => onDeleteHarvest(item.id)}
                    className="text-zinc-650 hover:text-red-400 p-1"
                    title="Remove item"
                  >
                    <Trash2 className="w-3.5 h-3.5" />
                  </button>
                </div>

                {/* Sell alarm deadline section */}
                {!isSold && (
                  <div className="mb-3 p-2 bg-zinc-950/80 rounded-xl border border-zinc-800/40">
                    <div className="flex justify-between items-center text-[10px] mb-1 font-mono">
                      <span className="text-zinc-400 flex items-center gap-1">
                        <Clock className="w-3 h-3 text-amber-500" /> Deadline Freshness
                      </span>
                      <span className={`font-bold ${logistics.iconColor}`}>
                        {logistics.label} ({logistics.freshness}%)
                      </span>
                    </div>
                    <div className="w-full bg-zinc-850 h-1.5 rounded-full overflow-hidden">
                      <div 
                        className={`h-full transition-all duration-500 ${
                          logistics.freshness > 50 ? "bg-teal-500" : logistics.freshness > 20 ? "bg-amber-500" : "bg-red-500"
                        }`}
                        style={{ width: `${logistics.freshness}%` }}
                      ></div>
                    </div>
                    <div className="text-[8px] text-zinc-500 font-mono mt-1 text-right">
                      Spoils: {new Date(item.sellDeadline).toLocaleString()}
                    </div>
                  </div>
                )}

                {/* Footer and buttons */}
                <div className="flex justify-between items-center mt-2.5">
                  <div className="text-[9px] text-zinc-500 font-mono">
                    Harvest Date: {new Date(item.harvestDate).toLocaleDateString()}
                  </div>

                  {!isSold && (
                    <div className="flex items-center gap-1">
                      <button
                        type="button"
                        onClick={() => onSellHarvest(item.id)}
                        className={`px-3 py-1 text-[11px] font-bold rounded-lg border flex items-center gap-1 transition-all ${
                          isSpoiled 
                            ? "bg-zinc-800 border-zinc-700 text-zinc-400 cursor-not-allowed" 
                            : "bg-emerald-600/25 border-emerald-550/20 text-emerald-300 hover:bg-emerald-500 hover:text-black"
                        }`}
                        disabled={isSpoiled}
                      >
                        <DollarSign className="w-3 h-3" /> Mark as Sells
                      </button>
                      <button
                        type="button"
                        onClick={() => autofillReminder(item)}
                        className="p-1 text-amber-400 bg-zinc-900 border border-zinc-750 rounded-lg"
                        title="Alert me when time to sell"
                      >
                        <Calendar className="w-4 h-4" />
                      </button>
                    </div>
                  )}

                  {isSold && (
                    <span className="text-xs text-emerald-400 font-bold flex items-center gap-1 italic">
                      ✓ Transacted & Sold
                    </span>
                  )}
                </div>

              </div>
            );
          })
        )}
      </div>

      {/* Freshness guide */}
      <div className="p-3.5 bg-zinc-900 border border-zinc-850 rounded-2xl relative overflow-hidden">
        <h4 className="text-xs font-bold text-teal-400 mb-1 flex items-center gap-1">
          <Archive className="w-4 h-4" /> Post-Harvest Preservation Instructions
        </h4>
        <ul className="text-[10px] text-zinc-400 space-y-1 list-disc list-inside">
          <li>Morning harvesting safeguards vegetables from midday thermal dehydration.</li>
          <li>Leafy greens degrade at 50% value every 6 hours if exposed to dry breeze.</li>
          <li>Spritz moisture or preserve with wet leaves to trigger premium market bids.</li>
          <li>Log your upcoming mandi (market) timing and drive early to capitalize.</li>
        </ul>
      </div>

    </div>
  );
};
