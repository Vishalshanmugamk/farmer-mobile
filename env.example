import React, { useState } from "react";
import { Home, Plus, Calendar, Coins, CheckCircle, CreditCard, Clock, Bell, Trash2 } from "lucide-react";
import { Bill, Reminder } from "../types";

interface FamilyBillsModuleProps {
  bills: Bill[];
  reminders: Reminder[];
  onAddBill: (bill: Omit<Bill, "id" | "status">) => void;
  onDeleteBill: (id: string) => void;
  onPayBill: (id: string) => void;
  onAddReminder: (moduleId: "bills", title: string, desc: string, time: string, repeat: "none" | "daily" | "weekly") => void;
  currentTimeStr: string;
}

export const FamilyBillsModule: React.FC<FamilyBillsModuleProps> = ({
  bills,
  reminders,
  onAddBill,
  onDeleteBill,
  onPayBill,
  onAddReminder,
  currentTimeStr
}) => {
  const [showAddForm, setShowAddForm] = useState(false);
  const [showReminderForm, setShowReminderForm] = useState(false);

  // Bill form state
  const [billName, setBillName] = useState("");
  const [billCategory, setBillCategory] = useState<"school_fees" | "eb_bill" | "wifi_bill" | "appliance_emi" | "other">("eb_bill");
  const [amount, setAmount] = useState("");
  const [dueDate, setDueDate] = useState("");

  // Alarm state
  const [remTitle, setRemTitle] = useState("");
  const [remDesc, setRemDesc] = useState("");
  const [remTime, setRemTime] = useState("");
  const [remRepeat, setRemRepeat] = useState<"none" | "daily" | "weekly">("none");

  const handleCreateBill = (e: React.FormEvent) => {
    e.preventDefault();
    if (!billName || !amount || !dueDate) return;

    onAddBill({
      name: billName,
      category: billCategory,
      amount: Number(amount),
      dueDate,
    });

    setBillName("");
    setAmount("");
    setDueDate("");
    setShowAddForm(false);
  };

  const handleCreateReminder = (e: React.FormEvent) => {
    e.preventDefault();
    if (!remTitle || !remTime) return;
    onAddReminder(
      "bills",
      remTitle,
      remDesc || `Utility / Family bill payment reminder`,
      remTime,
      remRepeat
    );
    setRemTitle("");
    setRemDesc("");
    setRemTime("");
    setShowReminderForm(false);
  };

  const getBillTimingStatus = (bill: Bill) => {
    if (bill.status === "paid") return { label: "PAID", class: "text-emerald-400 bg-emerald-500/10 border-emerald-500/10" };
    
    try {
      const now = new Date(currentTimeStr.substring(0, 10)).getTime();
      const due = new Date(bill.dueDate).getTime();

      if (now > due) {
        return { label: "OVERDUE", class: "text-red-400 bg-red-500/10 border-red-500/10 animate-pulse font-bold" };
      }
      
      const diffDays = Math.ceil((due - now) / (1000 * 60 * 60 * 24));
      if (diffDays <= 3) {
        return { label: `Due in ${diffDays}d`, class: "text-amber-400 bg-amber-500/10 border-amber-500/10" };
      }

      return { label: `Due in ${diffDays}d`, class: "text-zinc-400 bg-zinc-900 border-zinc-800" };
    } catch {
      return { label: "Pending", class: "text-zinc-400 bg-zinc-900 border-zinc-800" };
    }
  };

  const autofillBillReminder = (bill: Bill) => {
    const timeOnly = currentTimeStr.split("T")[1]?.substring(0, 5) || "10:00";
    let prePrefix = "💳";
    if (bill.category === "eb_bill") prePrefix = "⚡";
    if (bill.category === "wifi_bill") prePrefix = "🌐";
    if (bill.category === "school_fees") prePrefix = "🎓";

    setRemTitle(`${prePrefix} Pay ${bill.name}`);
    setRemDesc(`Settle standard outstanding amount of ₹${bill.amount} on time to avert lines or disconnect penalties.`);
    setRemTime(timeOnly);
    setShowReminderForm(true);
  };

  const totalPending = bills
    .filter(b => b.status !== "paid")
    .reduce((sum, b) => sum + b.amount, 0);

  const getCategoryEmoji = (cat: string) => {
    switch (cat) {
      case "school_fees": return "🎓";
      case "eb_bill": return "⚡";
      case "wifi_bill": return "🌐";
      case "appliance_emi": return "📺";
      default: return "🏡";
    }
  };

  return (
    <div className="flex-1 overflow-y-auto px-4 py-3 pb-8 text-zinc-100 bg-zinc-950 font-sans cursor-default">
      
      {/* Header Info */}
      <div className="flex justify-between items-center mb-4">
        <div>
          <h2 className="text-lg font-black text-indigo-400 flex items-center gap-2">
            <Home className="w-5 h-5" /> Module 5: Family & Bills
          </h2>
          <p className="text-[11px] text-zinc-400">Track and schedule family school fees, EB bills, wifi wifi bills, and appliance EMIs</p>
        </div>
      </div>

      {/* Outstanding Total widget */}
      <div className="mb-4 bg-zinc-900 rounded-2xl border border-zinc-850 p-3.5 flex justify-between items-center font-sans">
        <div>
          <span className="text-[10px] text-zinc-500 uppercase tracking-wider block font-bold">Total Family Outstandings</span>
          <span className="text-2xl font-black text-indigo-400 font-mono">₹ {totalPending}</span>
        </div>
        <div className="text-right text-[10px] text-zinc-500">
          <span>{bills.filter(b => b.status === "paid").length} Settle / {bills.filter(b => b.status !== "paid").length} Outstanding</span>
        </div>
      </div>

      {/* Action triggers */}
      <div className="grid grid-cols-2 gap-2 mb-4 font-sans">
        <button
          type="button"
          onClick={() => { setShowAddForm(!showAddForm); setShowReminderForm(false); }}
          className="flex items-center justify-center gap-1.5 p-2 bg-indigo-500/10 border border-indigo-500/20 text-indigo-300 rounded-xl text-xs font-bold hover:bg-indigo-500/20 transition-all"
        >
          <Plus className="w-4 h-4" /> Add Household Bill
        </button>
        <button
          type="button"
          onClick={() => { setShowReminderForm(!showReminderForm); setShowAddForm(false); }}
          className="flex items-center justify-center gap-1.5 p-2 bg-amber-500/10 border border-amber-500/20 text-amber-500 rounded-xl text-xs font-bold hover:bg-amber-500/25 transition-all"
        >
          <Calendar className="w-4 h-4" /> Setup Alarm
        </button>
      </div>

      {/* Form 1: Add Bill */}
      {showAddForm && (
        <form onSubmit={handleCreateBill} className="mb-4 bg-zinc-900 border border-zinc-800 rounded-xl p-3 text-xs space-y-2.5">
          <h3 className="font-bold text-zinc-200">Register Family / Utility Bill</h3>

          <div className="space-y-1">
            <label className="text-zinc-400">Bill description name</label>
            <input 
              required
              type="text" 
              value={billName}
              onChange={e => setBillName(e.target.value)}
              placeholder="e.g. EB Power Bill, Rohan School Fees" 
              className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-200"
            />
          </div>

          <div className="grid grid-cols-2 gap-2">
            <div className="space-y-1">
              <label className="text-zinc-400">Bill Type Category</label>
              <select 
                value={billCategory}
                onChange={e => setBillCategory(e.target.value as any)}
                className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-200"
              >
                <option value="eb_bill">⚡ EB Power Bill</option>
                <option value="school_fees">🎓 School / College Fees</option>
                <option value="wifi_bill">🌐 Wifi / Internet Bill</option>
                <option value="appliance_emi">📺 Appliance EMI (TV/Fridge)</option>
                <option value="other">🏡 Other Household Bill</option>
              </select>
            </div>
            <div className="space-y-1">
              <label className="text-zinc-400">Bill Amount (₹)</label>
              <input 
                required
                type="number" 
                value={amount}
                onChange={e => setAmount(e.target.value)}
                placeholder="e.g. 750" 
                className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-200 font-mono"
              />
            </div>
          </div>

          <div className="space-y-1">
            <label className="text-zinc-400">Due Date (Select Date)</label>
            <input 
              required
              type="date" 
              value={dueDate}
              onChange={e => setDueDate(e.target.value)}
              className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-200 font-mono"
            />
          </div>

          <div className="flex gap-2 justify-end pt-1">
            <button 
              type="button" 
              onClick={() => setShowAddForm(false)}
              className="px-3 py-1.5 bg-zinc-800 border border-zinc-700 text-zinc-400 rounded hover:bg-zinc-700"
            >
              Cancel
            </button>
            <button 
              type="submit" 
              className="px-3 py-1.5 bg-indigo-600 border border-indigo-500 text-black font-bold rounded hover:bg-indigo-500"
            >
              Register Bill
            </button>
          </div>
        </form>
      )}

      {/* Form 2: Add Alarm Reminder */}
      {showReminderForm && (
        <form onSubmit={handleCreateReminder} className="mb-4 bg-zinc-900 border border-zinc-800 rounded-xl p-3 text-xs space-y-2.5">
          <h3 className="font-bold text-amber-500">Add Bill Due Repetitive Alarm</h3>

          <div className="space-y-1">
            <label className="text-zinc-400">Alarm Title</label>
            <input 
              required
              type="text" 
              value={remTitle} 
              onChange={e => setRemTitle(e.target.value)}
              placeholder="e.g. ⚡ Pay Electric Board Bill" 
              className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-100 font-bold"
            />
          </div>

          <div className="space-y-1">
            <label className="text-zinc-400">Description Notes</label>
            <input 
              type="text" 
              value={remDesc} 
              onChange={e => setRemDesc(e.target.value)}
              placeholder="e.g. Check EB water-pump meter readings. Keep cash active." 
              className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-200"
            />
          </div>

          <div className="grid grid-cols-2 gap-2">
            <div className="space-y-1">
              <label className="text-zinc-400">Trigger Alarm standard time</label>
              <input 
                required
                type="text" 
                value={remTime} 
                onChange={e => setRemTime(e.target.value)}
                placeholder="24h e.g. 09:30 or 19:15" 
                className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-100 font-mono"
              />
            </div>
            <div className="space-y-1">
              <label className="text-zinc-400">Alarm Type Pattern</label>
              <select 
                value={remRepeat} 
                onChange={e => setRemRepeat(e.target.value as any)}
                className="w-full bg-zinc-950 border border-zinc-800 p-2 rounded text-zinc-100"
              >
                <option value="none">One-time alert</option>
                <option value="daily">Daily repetitive (Every day)</option>
              </select>
            </div>
          </div>

          <div className="flex gap-2 justify-end pt-1">
            <button 
              type="button" 
              onClick={() => setShowReminderForm(false)}
              className="px-3 py-1.5 bg-zinc-800 border border-zinc-700 text-zinc-400 rounded hover:bg-zinc-700"
            >
              Cancel
            </button>
            <button 
              type="submit" 
              className="px-3 py-1.5 bg-amber-600 border border-amber-500 text-black font-semibold rounded hover:bg-amber-500"
            >
              Activate Alarm
            </button>
          </div>
        </form>
      )}

      {/* Bills display list */}
      <div className="space-y-3 mb-5">
        <h3 className="text-xs uppercase tracking-wider text-zinc-400 font-bold mb-1">Bills & College Fees Schedulers</h3>
        {bills.length === 0 ? (
          <div className="text-center py-6 bg-zinc-900 border border-zinc-850 rounded-2xl text-xs text-zinc-500">
            🏡 No household utility bill items registered. Add your bills and EMIs above to track!
          </div>
        ) : (
          bills.map(bill => {
            const statusStyle = getBillTimingStatus(bill);
            const isPaid = bill.status === "paid";

            return (
              <div 
                key={bill.id} 
                className={`p-3 bg-zinc-900 border rounded-2xl transition-all ${
                  isPaid 
                    ? "border-emerald-500/20 bg-emerald-500/5 opacity-80" 
                    : statusStyle.label === "OVERDUE" 
                      ? "border-red-500/50 bg-red-500/5 animate-pulse" 
                      : "border-zinc-800"
                }`}
              >
                {/* Header detail row */}
                <div className="flex justify-between items-start mb-2">
                  <div>
                    <h4 className="font-bold text-[14px] text-zinc-100 flex items-center gap-1.5">
                      <span className="text-lg">{getCategoryEmoji(bill.category)}</span>
                      {bill.name}
                    </h4>
                    <span className="text-[10px] text-zinc-400 block mt-0.5 font-mono">
                      Due Date limit: <span className="text-zinc-200 font-semibold">{bill.dueDate}</span>
                    </span>
                  </div>
                  <button 
                    type="button"
                    onClick={() => onDeleteBill(bill.id)}
                    className="text-zinc-650 hover:text-red-400 p-1"
                    title="Remove item"
                  >
                    <Trash2 className="w-3.5 h-3.5" />
                  </button>
                </div>

                {/* Settle panel */}
                <div className="flex justify-between items-center mt-3 pt-1 border-t border-zinc-800/40">
                  <div className="flex items-center gap-2">
                    <span className="text-sm font-black font-mono text-indigo-400">₹ {bill.amount}</span>
                    <span className={`text-[9px] font-bold px-2 py-0.5 rounded border ${statusStyle.class}`}>
                      {statusStyle.label}
                    </span>
                  </div>

                  {!isPaid && (
                    <div className="flex items-center gap-1">
                      <button
                        type="button"
                        onClick={() => onPayBill(bill.id)}
                        className="px-3.5 py-1 text-[11px] font-bold bg-indigo-600/25 border border-indigo-500/20 text-indigo-300 rounded-lg hover:bg-indigo-500 hover:text-black transition-all flex items-center gap-1 font-sans"
                      >
                        <CreditCard className="w-3.5 h-3.5" /> Pay Now
                      </button>
                      <button
                        type="button"
                        onClick={() => autofillBillReminder(bill)}
                        className="p-1 text-amber-400 bg-zinc-900 border border-zinc-750 rounded-lg"
                        title="Alert me when bill is approaching"
                      >
                        <Calendar className="w-4 h-4" />
                      </button>
                    </div>
                  )}

                  {isPaid && (
                    <span className="text-[11px] text-emerald-400 font-bold flex items-center gap-1 italic font-sans pr-1">
                      <CheckCircle className="w-3.5 h-3.5" /> Settle OK
                    </span>
                  )}
                </div>

              </div>
            );
          })
        )}
      </div>

      {/* Household budgeting tips */}
      <div className="p-3.5 bg-zinc-900 border border-zinc-850 rounded-2xl relative overflow-hidden">
        <h4 className="text-xs font-bold text-indigo-400 mb-1 flex items-center gap-1 cursor-default">
          <Bell className="w-4 h-4" /> Budget Optimization Advisories
        </h4>
        <ul className="text-[10px] text-zinc-400 space-y-1 list-disc list-inside">
          <li>Electric bills (EB) rise dramatically if irrigation pumps function past peak.</li>
          <li>Set automatic alarms 2 days before due dates to ensure sufficient bank reserves.</li>
          <li>Verify Wifi and appliance EMIs recur to avoid late surcharge structures.</li>
          <li>Use AI advisor module to ask for optimal local energy schedules.</li>
        </ul>
      </div>

    </div>
  );
};
